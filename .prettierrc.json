{
	"bracketSameLine": true,
	"bracketSpacing": true,
	"endOfLine": "lf",
	"goTemplateBracketSpacing": true,
	"overrides": [
		{
			"files": ["*.html", "*.gotmpl", "*.tmpl.*"],
			"options": {
				"parser": "go-template",
				"bracketSameLine": true
			}
		}
	],
	"plugins": ["prettier-plugin-toml", "prettier-plugin-go-template"],
	"singleQuote": true,
	"tabWidth": 4,
	"useTabs": true
}
